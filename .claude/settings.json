{
  "permissions": {
    "allow": [
      "Bash(python3 .claude/scripts/anki.py:*)",
      "Bash(python3 .claude/scripts/compiled-is-fresh.py:*)",
      "Bash(python3 .claude/scripts/depolymorphize.py:*)",
      "Bash(python3 .claude/scripts/find-inheritables.py:*)",
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(date *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Write(decks/**/compiled.md)",
      "Write(decks/**/depolymorphized.md)",
      "Read(decks/**/compiled.md)",
      "Read(decks/**/context.md)",
      "Write(/tmp/card-edit-context.md)",
      "Read(/tmp/card-edit-context.md)",
      "Write(/tmp/card-input.txt)",
      "Write(/tmp/card-generation-context.md)",
      "Read(/tmp/card-generation-context.md)",
      "Bash(claude -p --bare *)",
      "Write(.claude/agents/health-agent/health-findings.jsonl)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/health-agent/observe-session-health.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/health-agent/detect-health-issues.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/health-agent/detect-health-issues.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/turn-tracker.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/health-agent/observe-skill-start.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/health-agent/surface-session-health.py"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/log-instructions-loaded.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/log-permission-request.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/health-agent/log-permission-request.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/notify-meta-read.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/notify-context-read.py"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/health-agent/observe-skill-start-natural.py"
          }
        ]
      }
    ]
  }
}
