{
  "permissions": {
    "allow": [
      "Bash(python3 .claude/anki.py:*)",
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(date *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Write(/tmp/anki_payload*.json)",
      "Write(/tmp/anki_note_update*.json)",
      "Write(/tmp/card-input.txt)",
      "Write(/tmp/card-generation-context.md)",
      "Read(/tmp/card-generation-context.md)",
      "Bash(claude -p --bare *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/turn-tracker.py"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/log-instructions-loaded.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/log-permission-request.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/notify-meta-read.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/notify-context-read.py"
          }
        ]
      }
    ]
  }
}
